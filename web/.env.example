# Local dev: keep this on localhost unless your API is elsewhere.
# Production (Netlify): set this to your Cloud Run URL, e.g. https://branchlm-api-xxxxx-uc.a.run.app
VITE_API_BASE_URL=http://localhost:8000
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# Dev-only: when true, the login UI bypasses OTP email/code checks.
VITE_AUTH_DEV_BYPASS=false
