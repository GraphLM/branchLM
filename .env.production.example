# Domain(s) served by Caddy. Comma-separated.
# Start with preview domain, then add/switch to primary domain when ready.
APP_HOSTNAMES=preview.yourdomain.com,app.yourdomain.com

# CORS allowlist for FastAPI (comma-separated)
API_CORS_ORIGINS=https://preview.yourdomain.com,https://app.yourdomain.com
AUTH_DEV_BYPASS=false

# Supabase (backend)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Supabase (frontend build)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# OpenRouter (backend)
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
# OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_SITE_URL=https://app.yourdomain.com
# OPENROUTER_APP_NAME=branchLM
# OPENROUTER_TIMEOUT_SECONDS=20

# Optional Backboard
# BACKBOARD_API_KEY=YOUR_BACKBOARD_API_KEY
# BACKBOARD_BASE_URL=https://app.backboard.io/api
# BACKBOARD_ASSISTANT_ID=existing_assistant_id

# Optional request/model limits
# MAX_PROMPT_CHARS=4000
# MAX_HISTORY_MESSAGES=12
# MAX_COMPLETION_TOKENS=600
# MODEL_CONTEXT_WINDOW_TOKENS=8192
# MODEL_CONTEXT_WINDOW_OVERRIDES=openai/gpt-4o-mini:128000
# INPUT_TOKEN_SAFETY_MARGIN=256
# ESTIMATED_CHARS_PER_TOKEN=4
# CONTEXT_SUMMARY_MAX_CHARS=600
# RATE_LIMIT_PER_MINUTE=20
# RATE_LIMIT_BURST=4
# RATE_LIMIT_BURST_WINDOW_SECONDS=10
