SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
# Backend-only secret. Do NOT put this in the web/ app.
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"
# Dev-only: when true, accepts frontend dev bypass tokens (dev-bypass:*).
AUTH_DEV_BYPASS="false"

# Optional: allowed origins for CORS (comma-separated)
# API_CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

# OpenRouter server-side LLM settings
OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY"
# OPENROUTER_MODEL="openai/gpt-4o-mini"
# OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
# OPENROUTER_SITE_URL="http://localhost:5173"
# OPENROUTER_APP_NAME="branchLM"
# OPENROUTER_TIMEOUT_SECONDS="20"

# Request and generation limits
# MAX_PROMPT_CHARS="4000"
# MAX_HISTORY_MESSAGES="12"
# MAX_COMPLETION_TOKENS="600"
# MODEL_CONTEXT_WINDOW_TOKENS="8192"
# MODEL_CONTEXT_WINDOW_OVERRIDES="openai/gpt-4o-mini:128000,anthropic/claude-sonnet-4:200000"
# INPUT_TOKEN_SAFETY_MARGIN="256"
# ESTIMATED_CHARS_PER_TOKEN="4"
# CONTEXT_SUMMARY_MAX_CHARS="600"
# RATE_LIMIT_PER_MINUTE="20"
# RATE_LIMIT_BURST="4"
# RATE_LIMIT_BURST_WINDOW_SECONDS="10"
